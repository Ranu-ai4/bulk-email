# Resend API Configuration
# Rename this file to .env before running

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
FROM_EMAIL=support@yourdomain.com
FROM_NAME=SAIF Support

# Email Subject
EMAIL_SUBJECT=SAIF Newsletter - Important Update

# File Paths (relative to script location)
CSV_FILE=emails.csv
IMAGE_FILE=newsletter.png
PDF_FILE=newsletter.pdf
HTML_TEMPLATE=template.html

# Rate Limiting (emails per second, Resend free tier allows 2/sec, paid allows 100/sec)
RATE_LIMIT=2


